{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:smoke_screen_big",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/campfire_smoke"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 8000,
        "max_particles": 800
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.5
      },
      "minecraft:emitter_shape_sphere": {
        "radius": 1,
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "v.particle_random_1 * 12 + 2"
      },
      "minecraft:particle_initial_speed": "Math.random(1.5, 30.5)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": "v.particle_age * 5"
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "math.exp(-0.1 * v.particle_lifetime / v.particle_age) * 5",
          "math.exp(-0.1 * v.particle_lifetime / v.particle_age) * 5"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 1,
          "texture_height": 12,
          "uv": [0, "Math.floor(variable.particle_random_2 * 12)"],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_motion_collision": {
        "enabled": "variable.particle_age > 1",
        "collision_radius": 0.25
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          1,
          1,
          1,
          "math.min((1 - v.particle_age / v.particle_lifetime) * 2, 1)"
        ]
      }
    }
  }
}
