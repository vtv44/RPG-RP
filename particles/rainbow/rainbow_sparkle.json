{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:rainbow_sparkle",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/sparkle"
      }
    },
    "components": {
      "minecraft:emitter_initialization": {
        "creation_expression": "variable.radius = 2.5;"
      },
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 2500,
        "max_particles": 498
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_sphere": {
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "v.particle_random_4 * 2 + 2"
      },
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "math.sin(v.particle_random_1 * 360) * (0.5 - math.exp(-5 * (v.particle_age / v.particle_lifetime)) + 2) * (v.particle_random_3 + 1)",
          0,
          "math.cos(v.particle_random_1 * 360) * (0.5 - math.exp(-5 * (v.particle_age / v.particle_lifetime)) + 2) * (v.particle_random_3 + 1)"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_lifetime - v.particle_age) * 0.06",
          "(v.particle_lifetime - v.particle_age) * 0.06"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 64,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 16],
            "frames_per_second": 15,
            "max_frame": 4,
            "loop": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "variable.particle_random_3",
          "gradient": {
            "0.0": "#ffd71c1c",
            "0.16": "#ffffdf00",
            "0.33": "#ff08ff00",
            "0.5": "#ff00ffff",
            "0.67": "#ff0000ff",
            "0.83": "#ffff00ff",
            "1.0": "#ffe21111"
          }
        }
      }
    }
  }
}
