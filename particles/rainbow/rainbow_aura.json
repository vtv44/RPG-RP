{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:rainbow_aura",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/sparkle"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 10
      },
      "minecraft:emitter_lifetime_once": {},
      "minecraft:emitter_shape_point": {
        "offset": [
          "math.sin(v.particle_random_1 * 360) * v.particle_random_2",
          0,
          "math.cos(v.particle_random_1 * 360) * v.particle_random_2"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "v.particle_random_4 * 1 + 2"
      },
      "minecraft:particle_initial_speed": 0,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, "0.4 * v.particle_random_2", 0]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_lifetime - v.particle_age) * 0.06",
          "(v.particle_lifetime - v.particle_age) * 0.06"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 64,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 16],
            "frames_per_second": 15,
            "max_frame": 4,
            "loop": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_random_1",
          "gradient": {
            "0.0": "#ffd71c1c",
            "0.16": "#ffffdf00",
            "0.33": "#ff08ff00",
            "0.5": "#ff00ffff",
            "0.67": "#ff0000ff",
            "0.83": "#ffff00ff",
            "1.0": "#ffe21111"
          }
        }
      }
    }
  }
}
