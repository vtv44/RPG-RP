{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:rainbow_z",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/sparkle"
      }
    },
    "curves": {
      "variable.rainbow": {
        "type": "catmull_rom",
        "input": "variable.particle_random_3",
        "horizontal_range": 1,
        "nodes": [1, 0, 1, 1.18]
      }
    },
    "components": {
      "minecraft:emitter_initialization": {
        "creation_expression": "variable.radius = 2.5;"
      },
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 2500,
        "max_particles": 498
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_point": {
        "offset": [
          0,
          "math.sin(v.particle_random_2 * 180) * (2.5 - variable.particle_random_3)",
          "math.cos(v.particle_random_2 * 180) * (2.5 - variable.particle_random_3)"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "v.particle_random_1 * 3 + 1"
      },
      "minecraft:particle_initial_speed": 0,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, "-0.1 + (v.particle_age * -0.5)", 0]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_age - v.particle_lifetime) * (v.particle_age - v.particle_lifetime) * 0.02",
          "(v.particle_age - v.particle_lifetime) * (v.particle_age - v.particle_lifetime) * 0.02"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 64,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 16],
            "frames_per_second": 15,
            "max_frame": 4,
            "loop": true
          }
        }
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.4,
        "collision_radius": 0.1
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "variable.rainbow",
          "gradient": {
            "0.0": "#ffd71c1c",
            "0.16": "#ffffdf00",
            "0.33": "#ff08ff00",
            "0.5": "#ff00ffff",
            "0.67": "#ff0000ff",
            "0.83": "#ffff00ff",
            "1.0": "#ffe21111"
          }
        }
      }
    }
  }
}
