{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:rainbow_converge",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/sparkle"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 2500,
        "max_particles": 498
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_sphere": {
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "v.particle_random_4 * 1 + 1"
      },
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "math.sin(v.particle_random_1 * 180) * math.cos(v.particle_random_2 * 360) * (v.particle_lifetime / v.particle_age - 1)",
          "math.sin(v.particle_random_1 * 180) * math.sin(v.particle_random_2 * 360) * (v.particle_lifetime / v.particle_age - 1)",
          "math.cos(v.particle_random_1 * 180) * (v.particle_lifetime / v.particle_age - 1)"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_age / v.particle_lifetime) * 0.3 * v.particle_random_3 + 0.05",
          "(v.particle_age / v.particle_lifetime) * 0.3 * v.particle_random_3 + 0.05"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 64,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [0, 16],
            "frames_per_second": 15,
            "max_frame": 4,
            "loop": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_random_1 * v.particle_random_2 * (v.particle_lifetime / v.particle_age)",
          "gradient": {
            "0.0": "#ffd71c1c",
            "0.64": "#ffffdf00",
            "1.32": "#ff08ff00",
            "2.0": "#ff00ffff",
            "2.68": "#ff0000ff",
            "3.32": "#ffff00ff",
            "4.0": "#ffe21111"
          }
        }
      }
    }
  }
}
