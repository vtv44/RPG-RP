{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:fire_spark_eruption_huge",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/white_dot"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 1024
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": ["math.cos(v.particle_random_1 * 360) * math.sqrt(v.particle_random_3)", 0, "math.sin(v.particle_random_1 * 360) * math.sqrt(v.particle_random_3)"],
				"direction": ["math.cos(v.particle_random_1 * 360)", "v.emitter_random_1 * 2 + 4", "math.sin(v.particle_random_1 * 360)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.particle_random_2 * v.particle_random_2 * 10 + 1.5"
			},
			"minecraft:particle_initial_speed": "12 + v.particle_random_2 * 48",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "(-20 - v.particle_random_2 * 8) * (1 - v.particle_age / v.particle_lifetime)", 0],
				"linear_drag_coefficient": "1 + (2 - v.particle_random_2 * 2)"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["math.max((1 - (v.particle_age / v.particle_lifetime) * 4) / 1.5, 0.02)", "(1 - v.particle_age / v.particle_lifetime) / 40"],
				"facing_camera_mode": "lookat_direction"
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 1,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.18": "#FFFF4F00",
						"0.44": "#FF770000",
						"0.75": "#FF000000",
						"1.0": "#00000000"
					}
				}
			}
		}
	}
}