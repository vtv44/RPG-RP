{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:fire_field",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 500,
				"max_particles": 1000
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.5
			},
			"minecraft:emitter_shape_point": {
				"direction": [0, 1, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "1 / Math.Random(1, 5) + 1"
			},
			"minecraft:particle_motion_parametric": {
				"relative_position": ["(math.round(v.particle_random_4) ? math.cos(v.particle_age / v.particle_lifetime * 180) : math.sin(v.particle_age / v.particle_lifetime * 180)) * (v.particle_random_1 * 2 - 1) * 6", "math.cos(v.particle_age / v.particle_lifetime * 360) * (v.particle_random_2 * 2 - 1) * 2", "(!math.round(v.particle_random_4) ? math.cos(v.particle_age / v.particle_lifetime * 180) : math.sin(v.particle_age / v.particle_lifetime * 180)) * (v.particle_random_3 * 2 - 1) * 6"]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(1 - v.particle_age / v.particle_lifetime) / 5", "(1 - v.particle_age / v.particle_lifetime) / 5"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 3],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"enabled": "false",
				"collision_radius": 0.1
			}
		}
	}
}