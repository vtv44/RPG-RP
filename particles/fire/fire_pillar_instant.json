{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:fire_pillar_instant",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 600,
        "max_particles": 1000
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_disc": {
        "radius": 0.5,
        "direction": [0, 1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "1 / Math.Random(1, 5) + 1"
      },
      "minecraft:particle_initial_speed": "((variable.particle_random_1 * 4) * ((variable.emitter_age / variable.emitter_lifetime) * 4.6) + 2)",
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(0.1 + variable.particle_random_1*0.1) - (0.1 * variable.particle_age)",
          "(0.1 + variable.particle_random_1*0.1) - (0.1 * variable.particle_age)"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [0, 3],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_motion_collision": {
        "enabled": "false",
        "collision_radius": 0.1
      }
    }
  }
}
