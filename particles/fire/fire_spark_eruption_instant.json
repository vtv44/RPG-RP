{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:fire_spark_eruption_instant",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/white_dot"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 12
			},
			"minecraft:emitter_lifetime_once": {},
			"minecraft:emitter_shape_disc": {
				"radius": 0.2,
				"direction": ["math.random(-0.15,0.15)", 1, "math.random(-0.15,0.15)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.particle_random_1 * 3 + 3"
			},
			"minecraft:particle_initial_speed": "18 + v.particle_random_1 * 18",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "(-20 - v.particle_random_1 * 8) * (1 - v.particle_age / v.particle_lifetime)", 0],
				"linear_drag_coefficient": "1 + (2 - v.particle_random_1 * 2)"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["math.max((1 - (v.particle_age / v.particle_lifetime) * 8) / 1.5, 0.02)", "(1 - v.particle_age / v.particle_lifetime) / 40"],
				"facing_camera_mode": "lookat_direction"
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 1,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.13": "#FFFF4F00",
						"0.37": "#FF770000",
						"0.64": "#FF000000",
						"1.0": "#00000000"
					}
				}
			}
		}
	}
}