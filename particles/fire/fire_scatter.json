{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:fire_scatter",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/white_dot"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 64
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, 0, 0],
				"direction": ["math.random(-1,1)", "math.random(-1,1)", "math.random(-1,1)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.particle_random_1 * 3 + 3"
			},
			"minecraft:particle_initial_speed": "12 + v.particle_random_1 * 10",
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": "2 + (3 - v.particle_random_1 * 3)"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["math.max((1 - (v.particle_age / v.particle_lifetime) * 6) / 2, 0.02)", "(1 - v.particle_age / v.particle_lifetime) / 40"],
				"facing_camera_mode": "lookat_direction"
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 1,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.13": "#FFFF4F00",
						"0.37": "#FF770000",
						"0.66": "#FF000000",
						"0.94": "#00000000"
					}
				}
			}
		}
	}
}