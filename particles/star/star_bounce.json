{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:star_bounce",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/star_big"
      }
    },
    "events": {
      "bounce": {
        "sequence": [
          {
            "particle_effect": {
              "effect": "ptl:star_eruption",
              "type": "emitter"
            }
          }
        ]
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0.6, 0],
        "direction": [
          "v.particle_random_1 * 2 - 1",
          10,
          "v.particle_random_2 * 2 - 1"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 15
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)",
        "rotation_rate": "math.random(100,300)"
      },
      "minecraft:particle_initial_speed": "30 + v.particle_random_3 * 10",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -15, 0],
        "rotation_drag_coefficient": 0.02
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["4 + v.emitter_random_1 * 2", "4 + v.emitter_random_1 * 2"],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.8,
        "collision_radius": 0.5,
        "events": [
          {
            "event": "bounce",
            "min_speed": 0
          }
        ]
      }
    }
  }
}
