{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:star_flow",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/star"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 400,
        "max_particles": 1000
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_disc": {
        "radius": "v.emitter_age * 20",
        "surface_only": true,
        "direction": [0, 1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "(v.emitter_age * 7) + (v.particle_random_1 * 3) + (v.particle_random_2 * 2 - 1)"
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)",
        "rotation_rate": "math.random(5,200)"
      },
      "minecraft:particle_initial_speed": "12 - v.particle_random_1 * 4 + v.emitter_age * 2",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, "-7 + v.particle_random_1 * 2", 0],
        "rotation_drag_coefficient": 0.1
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "v.particle_random_1 * 0.15 + (v.particle_lifetime / (v.particle_age + 1) - 1) / 6",
          "v.particle_random_1 * 0.15 + (v.particle_lifetime / (v.particle_age + 1) - 1) / 6"
        ],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.4,
        "collision_radius": 0.1
      },
      "minecraft:particle_appearance_tinting": {
        "color": [1, 1, 1, "1 - (v.particle_age / v.particle_lifetime)"]
      }
    }
  }
}
