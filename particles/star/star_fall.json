      "minecraft:particle_initial_speed": "4 - v.particle_random_1 * 4",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          0,
          "-14 + (v.particle_random_1 * 8) + (v.particle_random_2 * 4 - 2)",
          0
        ],
        "rotation_drag_coefficient": 0.1
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "v.particle_random_1 * 0.15 + 0.1",
          "v.particle_random_1 * 0.15 + 0.1"
        ],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.4,
        "collision_radius": 0.1
      },
      "minecraft:particle_appearance_tinting": {
        "color": [1, 1, 1, "1 - (v.particle_age / v.particle_lifetime)"]
      }
    }
  }
