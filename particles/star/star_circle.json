{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:star_circle",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/star"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 400,
        "max_particles": 10000
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.25
      },
      "minecraft:emitter_shape_point": {
        "direction": [
          "math.cos((v.emitter_age / v.emitter_lifetime) * 385)",
          0,
          "math.sin((v.emitter_age / v.emitter_lifetime) * 385)"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 1
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)",
        "rotation_rate": "math.random(5,200)"
      },
      "minecraft:particle_initial_speed": "math.random(10,24)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 5
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "v.particle_random_1 * 0.15 + 0.1",
          "v.particle_random_1 * 0.15 + 0.1"
        ],
        "facing_camera_mode": "lookat_xyz"
      }
    }
  }
}
