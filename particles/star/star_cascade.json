{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:star_cascade",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/star"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 6
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_disc": {
        "radius": 4,
        "direction": [0, -1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "0.3 + ((1 - v.particle_random_1) * 2)"
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)",
        "rotation_rate": "math.random(5,200)"
      },
      "minecraft:particle_initial_speed": "46 + v.particle_random_1 * 32",
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_random_1 * 0.15 + 0.1) * math.min((v.particle_lifetime / v.particle_age - 1) * 6, 3)",
          "(v.particle_random_1 * 0.15 + 0.1) * math.min((v.particle_lifetime / v.particle_age - 1) * 6, 3)"
        ],
        "facing_camera_mode": "rotate_xyz"
      }
    }
  }
}
