{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:golden_clash_3",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/swell"
      }
    },
    "curves": {
      "variable.und_curve": {
        "type": "catmull_rom",
        "input": "v.particle_age",
        "horizontal_range": "v.particle_lifetime",
        "nodes": [1, 1, 1, 1, 0.95, 0.73, 0.21, -0.75]
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 350
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {},
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "0.2 + ((1 - v.particle_random_2) * 0.4)"
      },
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "math.sin(v.particle_random_1 * 360) * (6 + (3 * math.floor(v.particle_random_2 * 3))) + (0.4 - v.particle_random_3 * 0.8)",
          0,
          "math.cos(v.particle_random_1 * 360) * (6 + (3 * math.floor(v.particle_random_2 * 3))) + (0.4 - v.particle_random_3 * 0.8)"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.2 * (1 - (v.particle_age / v.particle_lifetime))",
          "v.particle_lifetime / (v.particle_age + 0.1)"
        ],
        "facing_camera_mode": "rotate_y",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [0, 0],
          "uv_size": [16, 16]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FFE0A400",
            "0.56": "#ffffffff"
          }
        }
      }
    }
  }
}
