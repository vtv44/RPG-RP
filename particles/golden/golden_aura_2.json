{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:golden_aura_2",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 300,
        "max_particles": 3000
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_disc": {
        "offset": [0, -0.15, 0],
        "radius": 0.4,
        "direction": [
          "v.particle_random_2 * 2 - 1",
          0.4,
          "v.particle_random_3 * 2 - 1"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 0.8
      },
      "minecraft:particle_initial_speed": "12 + v.particle_random_1 * 8",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "v.particle_random_2 * -64 + 32",
          0,
          "v.particle_random_3 * -64 + 32"
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "1.1 * (1 - v.particle_age / v.particle_lifetime) * v.particle_random_1",
          "0.1 * (1 - v.particle_age / v.particle_lifetime) * v.particle_random_1"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": ["0 + math.floor(v.particle_random_1 * 8)", 11],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FFFFC100",
            "0.5": "#FFFFFFFF"
          }
        }
      }
    }
  }
}
