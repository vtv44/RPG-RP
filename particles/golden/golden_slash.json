{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:golden_slash",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/swell"
      }
    },
    "curves": {
      "variable.und_curve": {
        "type": "catmull_rom",
        "input": "v.particle_age",
        "horizontal_range": "v.particle_lifetime",
        "nodes": [1, 1, 1, 1, 0.95, 0.73, 0.21, -0.75]
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 20
      },
      "minecraft:emitter_lifetime_once": {},
      "minecraft:emitter_shape_sphere": {
        "offset": [
          "v.emitter_random_1 * 1.4 - 0.7",
          "v.emitter_random_2 * 1.4 - 0.7",
          "v.emitter_random_3 * 1.4 - 0.7"
        ],
        "radius": 0.2,
        "direction": "inwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "0.2 + (v.particle_random_2 * 1.6)"
      },
      "minecraft:particle_initial_speed": 0,
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_motion_parametric": {
        "rotation": "v.emitter_random_4 * 360"
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "math.max(0.1 * (v.particle_lifetime / v.particle_age) - 0.1, 0)",
          "(v.particle_lifetime / v.particle_age * 5)"
        ],
        "facing_camera_mode": "rotate_y",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [0, 0],
          "uv_size": [16, 16]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#FFE0A400",
            "0.56": "#ffffffff"
          }
        }
      }
    }
  }
}
