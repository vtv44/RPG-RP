{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:explode_flagment",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/campfire_smoke"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 30,
        "max_particles": 200
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": "math.random(1, 5) + 2"
      },
      "minecraft:emitter_shape_point": {
        "offset": [
          "math.cos(v.emitter_random_1 * 360) * ((5 * v.emitter_random_3 + 10) * v.emitter_age) + ((v.emitter_random_1 - v.emitter_random_2) * 9)",
          "math.sin((v.emitter_random_4 * 40 + 160) * (v.emitter_age / v.emitter_lifetime)) * (30 * v.emitter_random_3 + 30) + ((v.emitter_random_2 + v.emitter_random_3) * 6)",
          "math.sin(v.emitter_random_2 * 360) * ((5 * v.emitter_random_3 + 10) * v.emitter_age) + ((v.emitter_random_3 - v.emitter_random_1) * 9)"
        ],
        "direction": [0, 1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 6
      },
      "minecraft:particle_expire_if_not_in_blocks": ["minecraft:air"],
      "minecraft:particle_initial_speed": "Math.random(0.5, 2)",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, 0.4, 0]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "(v.particle_lifetime - v.particle_age) / 3",
          "(v.particle_lifetime - v.particle_age) / 3"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 1,
          "texture_height": 12,
          "uv": [0, "Math.floor(variable.particle_random_2 * 12)"],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_motion_collision": {
        "enabled": "variable.particle_age > 1",
        "collision_radius": 0.25
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": [1, 1, 1, 1]
      }
    }
  }
}
