{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:shadow_sphere",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/white_dot"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": "600 * (0.2 + v.emitter_age)",
        "max_particles": 168
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.6
      },
      "minecraft:emitter_shape_sphere": {
        "radius": "v.emitter_age * 6",
        "surface_only": true,
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "1 + (0.2 * v.particle_random_1)"
      },
      "minecraft:particle_initial_speed": "2 * v.emitter_age * 2",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 2
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "math.sin(v.particle_age / v.particle_lifetime * 180) * (0.3 + v.particle_random_1) * 0.7",
          "math.sin(v.particle_age / v.particle_lifetime * 180) * (0.3 + v.particle_random_1) * 0.7"
        ],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_appearance_tinting": {
        "color": [0, 0, 0, 1]
      }
    }
  }
}
