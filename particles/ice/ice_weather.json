{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:ice_weather",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 400,
				"max_particles": 200
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.4
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 1,
				"direction": ["math.random(-2,2)", "math.random(-2,2)", "math.random(-2,2)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(6,10)"
			},
			"minecraft:particle_initial_speed": "v.particle_random_1 * 3 + 1",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -0.8, 0],
				"linear_drag_coefficient": 0.4
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(1 - v.particle_age / v.particle_lifetime) * 2", "(1 - v.particle_age / v.particle_lifetime) * 2"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [4, 2],
					"uv_size": [4, 4]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_2",
					"gradient": {
						"0.0": "#8FFFFFFF",
						"0.49": "#8F3CDBFF"
					}
				}
			}
		}
	}
}