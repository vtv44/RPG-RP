{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:ice_ball",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 700,
				"max_particles": 1000
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.2
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 0.5,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 6
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": 10
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(2-(math.min(v.particle_lifetime / v.particle_age - 1, 100)/50)) * (1-v.particle_random_2) * 4", "math.min(0.1 * (1 - v.particle_age / v.particle_lifetime) * 20, 0.1 + (1-v.particle_random_2) * 0.1 + (v.particle_random_4 * 0.3))"],
				"facing_camera_mode": "lookat_direction",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [8, 11],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_2 * 1.8",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"1.0": "#FF3CDBFF"
					}
				}
			}
		}
	}
}