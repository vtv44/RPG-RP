{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:hell_frog",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 360,
        "max_particles": 120
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.5
      },
      "minecraft:emitter_shape_disc": {
        "radius": 10,
        "direction": ["math.random(-5,5)", 8, "math.random(-5,5)"]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 6
      },
      "minecraft:particle_initial_speed": "4 + (v.particle_random_1 * 16)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 5
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "1 + v.particle_random_1 * 6",
          "math.min(0.1 * (1 - v.particle_age / v.particle_lifetime) * 20, 0.1 + v.particle_random_1 * 0.1)"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 32,
          "texture_height": 32,
          "uv": [15, 22],
          "uv_size": [1, 2]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_random_1",
          "gradient": {
            "0.0": "#FFFF0000",
            "1.0": "#FF101010"
          }
        }
      }
    }
  }
}
