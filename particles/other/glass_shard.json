{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:glass_shard",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/glass_shard"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 200,
        "max_particles": 100
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_sphere": {
        "radius": 1,
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 8
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)",
        "rotation_rate": "math.random(-720,720)"
      },
      "minecraft:particle_initial_speed": "4 * math.random(0,4)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 1,
        "rotation_drag_coefficient": 1
      },
      "minecraft:particle_appearance_billboard": {
        "size": [1, 1],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 2,
          "texture_height": 2,
          "uv": [
            "math.floor(v.particle_random_1 * 2)",
            "math.floor(v.particle_random_2 * 2)"
          ],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          1,
          1,
          1,
          "math.min(1 - v.particle_age / v.particle_lifetime, 0.75)"
        ]
      }
    }
  }
}
