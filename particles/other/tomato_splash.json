{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:tomato_splash",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 1
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0.01, 0],
        "direction": [0, -1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 5
      },
      "minecraft:particle_initial_spin": {
        "rotation": "math.random(0,360)"
      },
      "minecraft:particle_initial_speed": 1,
      "minecraft:particle_appearance_billboard": {
        "size": [
          "v.particle_random_1 * 0.8 + 0.4",
          "v.particle_random_1 * 0.8 + 0.4"
        ],
        "facing_camera_mode": "direction_z",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": ["5 + math.floor(v.particle_random_2 * 3)", 0],
          "uv_size": [1, 1]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "0.75 + v.particle_random_1 * 0.15",
          "0.2 + v.particle_random_1 * 0.05",
          "0.085 + v.particle_random_1 * 0.025",
          "1 - v.particle_age / v.particle_lifetime"
        ]
      }
    }
  }
}
