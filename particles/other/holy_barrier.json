        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "flipbook": {
            "base_UV": [7, 11],
            "size_UV": [1, 1],
            "step_UV": [-1, 0],
            "max_frame": 8,
            "stretch_to_lifetime": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [1, 1, 1, 1]
      }
    }
  }
