{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:hell_aura",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 60,
        "max_particles": 1200
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.1
      },
      "minecraft:emitter_shape_point": {
        "offset": [
          "math.cos(v.particle_random_1 * 360) * v.particle_random_3 * 4",
          -0.1,
          "math.sin(v.particle_random_2 * 360) * v.particle_random_3 * 4"
        ],
        "direction": [
          "math.cos(v.particle_random_1 * 360) * 1.3",
          0.18,
          "math.sin(v.particle_random_2 * 360) * 1.3"
        ]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 6
      },
      "minecraft:particle_initial_speed": "4 + (v.particle_random_1 * 16)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 5
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "2 + v.particle_random_1 * 2",
          "math.min((v.particle_lifetime / v.particle_age - 1) * 4, 0.1 + v.particle_random_1 * 0.1)"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 32,
          "texture_height": 32,
          "uv": [15, 22],
          "uv_size": [1, 2]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "1 - v.particle_random_3",
          "gradient": {
            "0.0": "#FFFF0000",
            "1.0": "#FF101010"
          }
        }
      }
    }
  }
}
