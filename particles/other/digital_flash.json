{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:digital_flash",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 60
      },
      "minecraft:emitter_lifetime_once": {},
      "minecraft:emitter_shape_sphere": {
        "radius": 6,
        "direction": "inwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(1, 3)"
      },
      "minecraft:particle_initial_speed": 100,
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 16
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.particle_random_2 * (v.particle_lifetime / v.particle_age * 0.07)",
          "variable.particle_random_2 * (v.particle_lifetime / (v.particle_age + 0.01) * 0.001)"
        ],
        "facing_camera_mode": "lookat_direction",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": ["1 + (math.ceil(v.particle_random_1 * 7) * 8)", 89],
          "uv_size": [7, 7]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "Math.clamp(0.3 + variable.particle_random_4 / 7 + (variable.particle_random_3 > 0.2 ? 0.4 : 0), 0, 1)",
          "Math.clamp(0.2 + variable.particle_random_4 / 5, 0, 1)",
          "Math.clamp(0.88 + variable.particle_random_4 / 8, 0, 1)",
          1
        ]
      }
    }
  }
}
