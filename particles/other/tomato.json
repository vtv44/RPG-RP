{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "ptl:tomato",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/tomato"
      }
    },
    "events": {
      "splash": {
        "particle_effect": {
          "effect": "ptl:tomato_splash",
          "type": "emitter"
        }
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 50,
        "max_particles": 800
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0.2
      },
      "minecraft:emitter_shape_sphere": {
        "radius": 1,
        "direction": ["math.random(-1,1)", 2, "math.random(-1,1)"]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 5
      },
      "minecraft:particle_lifetime_events": {
        "expiration_event": "splash"
      },
      "minecraft:particle_initial_spin": {
        "rotation_rate": "math.random(-100,100)"
      },
      "minecraft:particle_initial_speed": "3 + math.random(0, 4)",
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          0,
          "-4 * v.particle_age + v.particle_random_1 * -2",
          0
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.15 + v.particle_random_1 * 0.1",
          "0.15 + v.particle_random_1 * 0.1"
        ],
        "facing_camera_mode": "rotate_xyz"
      },
      "minecraft:particle_motion_collision": {
        "collision_radius": 0,
        "enabled": "v.particle_age > 0.2",
        "expire_on_contact": true
      }
    }
  }
}
