{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ptl:digital_deluge",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/white_dot_2"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 1500,
				"max_particles": 2000
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 3
			},
			"minecraft:emitter_shape_point": {
				"offset": ["math.cos(variable.particle_random_3 * 360) * math.sqrt(variable.particle_random_1 * 1024)", -20, "math.sin(variable.particle_random_3 * 360) * math.sqrt(variable.particle_random_1 * 1024)"],
				"direction": [0, 1, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.5, 1)"
			},
			"minecraft:particle_initial_speed": "math.random(40, 980)",
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["math.min((v.particle_lifetime / (v.particle_age+0.05+(v.particle_random_4*0.05)) - 1), 3)", "(1 - v.particle_age / v.particle_lifetime) * (v.particle_random_2 * 192 - 16)"],
				"facing_camera_mode": "lookat_y",
				"uv": {
					"texture_width": 1,
					"texture_height": 2,
					"uv": [0, 0],
					"uv_size": [1, 2]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_1 + (v.particle_random_2 * 0.1 - 0.05) + math.random(-0.05,0.05)",
					"gradient": {
						"0.0": "#7AFFF8E0",
						"0.27": "#7DFF2410",
						"0.9": "#24FF0060",
						"0.99": "#3DD000FF"
					}
				}
			}
		}
	}
}